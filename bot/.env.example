# =============================================================================
# Crunchy Gherkins Gacha Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# === Secrets ===

TELEGRAM_AUTH_TOKEN=
DEBUG_TELEGRAM_AUTH_TOKEN=
GOOGLE_API_KEY=
SERVER_SECRET=                              # JWT signing secret for admin dashboard

# === Bot Identity ===

BOT_ADMIN=                                  # Telegram username of the production admin
DEBUG_BOT_ADMIN=                            # Telegram username of the debug admin

# === Infrastructure URLs ===

MINIAPP_URL=https://app.example.com
DEBUG_MINIAPP_URL=http://localhost:5173

# === Image Generation ===

IMAGE_GEN_MODEL=gemini-2.0-flash-exp        # Google Gemini model name

# === Database ===

DB_PATH=./data/cards.db                     # Absolute or relative path to SQLite DB
CURRENT_SEASON=0                            # Active game season (integer)

# === Database Tuning (optional — defaults shown) ===

# DB_CONNECTION_POOL_SIZE=6
# DB_CONNECTION_TIMEOUT_SECONDS=30
# DB_BUSY_TIMEOUT_MS=5000

# === Operational (optional) ===

# SHADOW_STAGGERED_USERNAMES=              # Comma-separated usernames for artificial claim delay
# DEBUG_MODE=0                             # Set to 1 to force debug mode without --debug flag
# NO_GENERATION=0                          # Set to 1 (with debug) to skip image generation
