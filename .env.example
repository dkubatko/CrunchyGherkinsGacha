# ─── Crunchy Gherkins TCG Docker Environment ─────────────────────────────
# Copy this file to .env and fill in your values.
# This file is used by docker-compose.yml via env_file.
#
# For local dev (Docker containers connecting to your local PostgreSQL):
#   host.docker.internal maps to your Mac's localhost from inside Docker.

# ─── Database ────────────────────────────────────────────────────────
# Local dev: your Mac's PostgreSQL (use host.docker.internal, not localhost)
DATABASE_URL=postgresql+psycopg://gacha:gacha@host.docker.internal:5432/gacha
# Production (Cloud SQL via proxy):
# DATABASE_URL=postgresql+psycopg://gacha:PASSWORD@cloud-sql-proxy:5432/gacha

# ─── Telegram Bot ────────────────────────────────────────────────────
TELEGRAM_AUTH_TOKEN=your-bot-token-here
# Debug mode vars (used when DEBUG_MODE=1):
# DEBUG_MODE=1
# DEBUG_TELEGRAM_AUTH_TOKEN=your-debug-bot-token-here
# DEBUG_BOT_ADMIN=your-telegram-username
# DEBUG_MINIAPP_URL=https://your-ngrok-url.ngrok-free.app

# ─── Telegram Bot API Server ────────────────────────────────────────
# Required for the tg-bot-api container (get from https://my.telegram.org)
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash

# ─── Google Gemini (AI image generation) ─────────────────────────────
GOOGLE_API_KEY=your-google-api-key
IMAGE_GEN_MODEL=gemini-2.0-flash-preview-image-generation

# ─── Bot Configuration ──────────────────────────────────────────────
BOT_ADMIN=your-telegram-username
CURRENT_SEASON=2
MINIAPP_URL=https://app.crunchygherkins.com

# ─── API Server ─────────────────────────────────────────────────────
SERVER_SECRET=generate-a-random-secret-here
# CORS_ORIGINS=https://app.crunchygherkins.com,https://admin.crunchygherkins.com,http://localhost:5173
# VITE_API_BASE_URL=  (set if frontend needs a custom API URL; nginx proxies /api/ by default)

# ─── Optional ────────────────────────────────────────────────────────
# DEBUG_MODE=1                         # Enable debug mode
# NO_GENERATION=1                      # Disable AI image generation (debug only)
# DB_CONNECTION_POOL_SIZE=6            # SQLAlchemy pool size
# DB_CONNECTION_TIMEOUT_SECONDS=30     # SQLAlchemy connection timeout
# SHADOW_STAGGERED_USERNAMES=          # Comma-separated usernames for artificial delays

# ─── Production Only (Cloud SQL) ────────────────────────────────────
# CLOUD_SQL_CONNECTION_NAME=project:region:instance
